# Supabase (required)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Roboflow YOLOv8 model endpoint (client-side, read note below)
# Format: https://detect.roboflow.com/YOUR_MODEL/VERSION
EXPO_PUBLIC_ROBOFLOW_MODEL_URL=https://detect.roboflow.com/your-model/1
EXPO_PUBLIC_ROBOFLOW_API_KEY=your-roboflow-api-key

# Claude Vision — SECURITY NOTE: This key is proxied through a Supabase Edge Function
# (supabase/functions/identify-specimen/index.ts) and NOT sent to the client.
# Set this in your Supabase project as a secret: supabase secrets set ANTHROPIC_API_KEY=...
# Do NOT prefix with EXPO_PUBLIC_ for the Edge Function secret.
ANTHROPIC_API_KEY=your-anthropic-api-key
